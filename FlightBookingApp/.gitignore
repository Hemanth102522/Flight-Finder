# --- Dependencies ---
# Never upload these; they are huge and can be re-installed via 'npm install'
node_modules/
jspm_packages/
web_modules/

# --- Environment Secrets (CRITICAL) ---
# This prevents your API keys (Amadeus, SkyScanner, etc.) from being public
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Build Outputs ---
# These are generated files from your build process
dist/
build/
out/
.next/
.serverless/

# --- Debug & Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# --- Operating System Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor / IDE Private Folders ---
.vscode/
.idea/
*.swp
*.swo

# --- Database (if using local SQLite or similar) ---
*.db
*.sqlite